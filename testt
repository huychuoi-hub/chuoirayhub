    TweenService:Create(Overlay, TweenInfo.new(0.5), {BackgroundTransparency = 1}):Play()
    
    task.wait(0.3)
    -- Hiện UI Chính
    ShowMainUI()
    
    task.wait(1)
    Circle:Destroy()
    BlackBar:Destroy()
    Overlay:Destroy()
    Blur:Destroy()
end)

