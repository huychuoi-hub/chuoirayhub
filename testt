-- Chạy Intro
task.spawn(function()
    -- 1. Xám màn hình & Blur chậm
    TweenService:Create(Overlay, TweenInfo.new(1.2), {BackgroundTransparency = 0.4}):Play()
    TweenService:Create(Blur, TweenInfo.new(1.2), {Size = 20}):Play()
    
    -- 2. Cục đen đi qua chậm
    TweenService:Create(BlackBar, TweenInfo.new(2, Enum.EasingStyle.Quint, Enum.EasingDirection.InOut), {Position = UDim2.new(1.2, 0, 0.4, 0)}):Play()
    
    -- 3. Hình tròn đi chậm vào GÓC PHẢI DƯỚI
    task.wait(0.5)
    TweenService:Create(Circle, TweenInfo.new(2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Position = UDim2.new(0.85, 0, 0.8, 0)}):Play()
    
    task.wait(2.2) -- Đợi hình tròn dừng ở góc
    task.wait(1)   -- Đợi thêm 1s như ý bạn
    
    -- 4. Hình tròn đi vào GIỮA và NỞ RA
    local ToCenter = TweenService:Create(Circle, TweenInfo.new(1.2, Enum.EasingStyle.Back, Enum.EasingDirection.InOut), {Position = UDim2.new(0.5, -40, 0.5, -40)})
